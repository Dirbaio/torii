# Keep the build context small. The Rust build needs only Cargo.{toml,lock},
# lolgateway/ (our crate), and pingora/ (vendored path deps).
target/
.git/
gateway-api/
kubeconfig
*.md
hack/
.vscode/
.claude/
.cargo-home/
env.txt
sandbox*.sh
# pingora's own target dirs / git, if any
pingora/target/
pingora/**/target/
